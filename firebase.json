{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "firebase-debug.log",
      "README.md",
      ".git/**",
      ".gitignore",
      "prueba/**"
    ],
    "cleanUrls": true,
    "trailingSlash": false,
    "headers": [
      {
        "source": "**/*.glb",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=604800,immutable"
          }
        ]
      },
      {
        "source": "**/*.{css,js,png}",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=3600"
          }
        ]
      }
    ]
  }
}
